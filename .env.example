# ── PostgreSQL ────────────────────────────────────────────────────
# These are used by the Postgres Docker container and the backend DATABASE_URL
POSTGRES_USER=vyapariq
POSTGRES_PASSWORD=vyapariq_secret
POSTGRES_DB=vyapariq

# Final connection string used by the app:
# DATABASE_URL=postgresql://vyapariq:vyapariq_secret@localhost:5433/vyapariq

# ── Backend (REQUIRED) ────────────────────────────────────────────
# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Secret used to sign OAuth session cookies
SESSION_SECRET=change_me_to_another_long_random_string

# Full URL of your frontend — used for CORS and OAuth redirects
# Local development: http://localhost:5174
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5174

NODE_ENV=development

# ── Google OAuth (OPTIONAL — leave blank to disable Google sign-in) ──
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match EXACTLY what you register in Google Cloud Console under
# "Authorised redirect URIs" for your OAuth client:
#   Local:      http://localhost:5001/api/auth/google/callback
#   Production: https://yourdomain.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# ── AI Service ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
